# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/combat_sports_db

# ─── Cache ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Message Queue ───────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://admin:password@localhost:5672

# ─── Auth (Clerk) ────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# ─── LLM Keys (via LiteLLM) ──────────────────────────────────────────────────
LITELLM_OPENAI_KEY=sk-your-openai-key-here
LITELLM_ANTHROPIC_KEY=sk-ant-your-anthropic-key-here
LITELLM_GEMINI_KEY=your-gemini-api-key-here
LITELLM_MASTER_KEY=sk-master-your-litellm-master-key-here

# ─── Service URLs ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_GATEWAY_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8000
REALTIME_SERVICE_URL=http://localhost:5000

# ─── Observability ────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
